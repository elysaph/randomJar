{
    "name": "randomjar",
    "version": "1.0.0",
    "private": true,
    "homepage": "https://elysaph.github.io/randomJar",
    "dependencies": {
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-scripts": "5.0.1",
        "typescript": "5.1.6",
        "uuid": "^9.0.0"
    },
    "scripts": {
        "start": "npm run build:local && npx serve -s build -l 3001",
        "dev": "react-scripts start",
        "build:local": "set PUBLIC_URL=/&& react-scripts build",
        "build": "react-scripts build",
        "test": "react-scripts test",
        "eject": "react-scripts eject",
        "predeploy": "npm run build",
        "deploy": "gh-pages -d build"
    },
    "eslintConfig": {
        "extends": [
            "react-app"
        ]
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "devDependencies": {
        "@types/react": "^18.2.0",
        "@types/react-dom": "^18.2.0",
        "@types/uuid": "^9.0.0",
        "ajv": "^8.12.0",
        "ajv-keywords": "^5.1.0",
        "autoprefixer": "^10.4.14",
        "gh-pages": "^5.0.0",
        "postcss": "^8.4.24",
        "serve": "^14.2.6",
        "tailwindcss": "^3.3.0"
    }
}